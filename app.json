{
  "expo": {
    "name": "SYK Social",
    "slug": "syk-social",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "syksocial",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sykmm.social"
    },
    "android": {
      "ndkVersion": "27.1.12297006",
      "adaptiveIcon": {
        "backgroundColor": "#1877F2",
        "foregroundImage": "./assets/icon.png"
      },
      "package": "com.sykmm.social"
    },
    "web": {
      "favicon": "./assets/icon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-build-properties",
      {
        "android": {
          "kotlinAsJavaSourceCompatibility": "21",
          "extraKotlinCompilerArgs": ["-nowarn"]
      }
    }
  }
}
